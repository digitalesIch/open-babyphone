<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/LinearLayout1"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context="org.openbabyphone.StartActivity" >

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/useChildDevice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/useAsChildDevice"
        android:textSize="16sp"
        style="@style/Widget.Material3.Button.ElevatedButton"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/childDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/childDescription"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/useChildDevice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/useParentDevice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/useAsParentDevice"
        android:textSize="16sp"
        style="@style/Widget.Material3.Button.ElevatedButton"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/childDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/parentDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/parentDescription"
        style="@style/TextAppearance.Material3.BodyMedium"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/useParentDevice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/settingsButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/parentDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
